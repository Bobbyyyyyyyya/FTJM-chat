{
  "name": "@ftjm/web",
  "version": "0.4.0",
  "description": "React web app",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "postinstall": "node -e \"try { require('fs').copyFileSync('.env.example', '.env.local', require('fs').constants.COPYFILE_EXCL); console.log('✅ .env.local created from .env.example'); } catch(e) { if(e.code !== 'EEXIST') console.error(e); }\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0",
    "crypto-js": "^4.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
