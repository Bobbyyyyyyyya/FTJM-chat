{
  "name": "@ftjm/main",
  "version": "0.4.27",
  "description": "Electron main process",
  "author": {
    "name": "FTJM Team",
    "email": "team@ftjm.chat"
  },
  "homepage": "https://ftjm.chat",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc --watch",
    "build": "npm run prebuild && tsc && npm run copy-web",
    "prebuild": "node -e \"const fs=require('fs'); const src='../../node_modules/electron'; const dest='node_modules/electron'; if(!fs.existsSync(dest)){try{fs.mkdirSync('node_modules',{recursive:true});fs.symlinkSync(src,dest,'dir')}catch(e){console.error('symlink failed:',e)}}\"",
    "copy-web": "node -e \"fs.cpSync('../web/dist', 'web-dist', {recursive: true, filter: (src) => !src.includes('node_modules')})\"",
    "start": "cd .. && npm run start",
    "electron:start": "NODE_ENV=development npx electron dist/main.js",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux",
    "type-check": "tsc --noEmit",
    "sign:verify": "codesign --verify --verbose=4 \"$(find release -name '*.app' -type d)\" && spctl -a -v \"$(find release -name '*.app' -type d)\""
  },
  "dependencies": {
    "electron-is-dev": "^3.0.1",
    "electron-updater": "^6.1.0",
    "fs-extra": "^11.2.0",
    "universalify": "^2.0.1",
    "graceful-fs": "^4.2.11",
    "jsonfile": "^6.1.0",
    "builder-util-runtime": "^9.2.1",
    "js-yaml": "^4.1.0",
    "lazy-val": "^1.0.5",
    "lodash.escaperegexp": "^4.1.2",
    "lodash.isequal": "^4.5.0",
    "semver": "^7.5.4",
    "tiny-typed-emitter": "^2.1.0",
    "debug": "^4.3.4",
    "sax": "^1.2.4",
    "ms": "^2.1.3",
    "argparse": "^2.0.1"
  },
  "devDependencies": {
    "electron": "^42.3.1",
    "electron-builder": "^24.6.0",
    "typescript": "^5.3.0"
  }
}
